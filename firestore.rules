rules_version = '2';

// ═══════════════════════════════════════════════════════════
//  StudyHub — Firestore Security Rules
//
//  HOW TO DEPLOY:
//  Option A (Firebase Console):
//    1. Go to Firebase Console → Firestore Database → Rules tab
//    2. Replace all content with these rules
//    3. Click "Publish"
//
//  Option B (Firebase CLI):
//    firebase deploy --only firestore:rules
// ═══════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users collection ────────────────────────────────────
    // Each user can only read and write their own document.
    // No other user (or unauthenticated visitor) can access it.
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // ── Deny everything else ────────────────────────────────
    // Any path not matched above is denied by default in
    // Firestore, but this makes the intent explicit.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
